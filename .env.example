# UnderCut F1 — environment variables
#
# Setup:
#   cp .env.example .env
#   cp .env.example apps/web/.env.local   # or copy only DATABASE_URL into apps/web/.env.local
#
# CURRENT_SEASON: set in repo root `.env` (loaded by apps/web via next.config.ts).
# Do NOT pin CURRENT_SEASON in apps/web/.env.local unless you need a local override.
#
# DATABASE_URL: required in apps/web/.env.local for Next.js server components (Prisma).

# Current F1 season year (defaults to calendar year when unset)
CURRENT_SEASON=2026

# Canonical site URL (required in production)
NEXT_PUBLIC_SITE_URL=https://undercut.ge

# PostgreSQL connection (required for @pitwall/db)
DATABASE_URL=postgresql://pitwall:pitwall@localhost:5432/pitwall

# Redis (live session KV, streams, pub/sub)
REDIS_URL=redis://localhost:6379

# WebSocket server (ws-server listens on WS_PORT; nginx proxies /socket.io/ in production)
WS_PORT=3001
REDIS_URL=redis://localhost:6379
# Local dev only — production uses same origin (https://undercut.ge) via nginx
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Enable mock live data in ws-server (no Redis/ingestion required)
MOCK=false

# OpenF1 OAuth (optional — enables live session data when subscribed)
# Without credentials, live detection falls back to Jolpica schedule + OpenF1 restriction signal.
# OPENF1_USERNAME=
# OPENF1_PASSWORD=
# OPENF1_ACCESS_TOKEN=
